{
  "name": "equipment-audit-front-end",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n VITE,OPEN \"npm:dev:server\" \"wait-on http://127.0.0.1:5173 && cmd /c start chrome http://127.0.0.1:5173\"",
    "dev:server": "vite --host 127.0.0.1 --port 5173",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "concurrently -n PREVIEW,OPEN \"npm:preview:server\" \"wait-on http://127.0.0.1:5174 && cmd /c start chrome http://127.0.0.1:5174\"",
    "preview:server": "vite preview --host 127.0.0.1 --port 5174 --strictPort"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "axios": "^1.13.6",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.576.0",
    "msw": "^2.12.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
